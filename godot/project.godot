; Engine configuration file.
; It's best edited using the editor GUI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="La Senda del Pietierno"
config/description="Libro interactivo de investidura — Grupo Scout 127"
config/version="0.5.3"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.7", "Mobile")
config/icon="res://icon.svg"

[autoload]

GameState="*res://autoload/GameState.gd"
SaveManager="*res://autoload/SaveManager.gd"
SceneRouter="*res://autoload/SceneRouter.gd"
FirebaseConfig="*res://firebase_config.gd"
FirebaseSync="*res://scripts/firebase_sync.gd"

[display]

window/handheld/orientation=4
window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
