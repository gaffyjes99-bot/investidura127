[gd_scene format=3]

[sub_resource type="GDScript" id="GDScript_1"]
script/source = "extends Control

func _ready() -> void:
	($CargandoLabel as Label).text = \"Script OK\"
	print(\"main _ready ejecutado\")
	get_tree().change_scene_to_file(\"res://scenes/onboarding/onboarding.tscn\")
"

[node name="Main" type="Control" script=SubResource("GDScript_1")]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.11, 0.17, 0.34, 1)

[node name="CargandoLabel" type="Label" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
theme_override_font_sizes/font_size = 28
theme_override_colors/font_color = Color(1, 0.85, 0.2, 1)
text = "Cargando expedicion..."
horizontal_alignment = 1
vertical_alignment = 1
